# Example environment variables for AJKMart
# Copy this file to .env and fill in the real values.

# Database
DATABASE_URL=postgresql://user:password@host:5432/ajkmart
CUSTOM_DATABASE_URL=

# App secrets
ADMIN_SECRET=change-me
ADMIN_USERNAME=admin
JWT_SECRET=change-me
ADMIN_JWT_SECRET=change-me
CSRF_SECRET=change-this-in-production

# API / frontend URLs
VITE_API_URL=https://api.yourdomain.com/api
VITE_API_BASE_URL=https://api.yourdomain.com
EXPO_PUBLIC_DOMAIN=yourdomain.com
APP_BASE_URL=https://yourdomain.com

# CORS / allowed origins
ALLOWED_ORIGINS=https://yourdomain.com,https://admin.yourdomain.com

# Email / SMTP
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="AJKMart <noreply@ajkmart.com>"

# Web push
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CONTACT_EMAIL=mailto:admin@yourdomain.com

# Authentication / security
RECAPTCHA_SECRET_KEY=
WHATSAPP_APP_SECRET=

# API integrations
AI_INTEGRATIONS_OPENAI_BASE_URL=
AI_INTEGRATIONS_OPENAI_API_KEY=

# Node
NODE_ENV=production
PORT=3000
