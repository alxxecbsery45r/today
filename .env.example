# Example environment variables for AJKMart
# Copy this file to .env and fill in the real values.

# Database
DATABASE_URL=postgresql://neondb_owner:npg_s6YEp4qkXPDz@ep-blue-cake-amu6yuja-pooler.c-5.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# App secrets
ADMIN_SECRET=admin-login-secret-1234567890
ADMIN_USERNAME=admin
JWT_SECRET=admin-secret-key-min-32-chars-1234567
ADMIN_JWT_SECRET=admin-secret-key-min-32-chars-123456
CSRF_SECRET=change-this-in-production

# API / frontend URLs
VITE_API_URL=https://api.yourdomain.com/api
VITE_API_BASE_URL=https://api.yourdomain.com
EXPO_PUBLIC_DOMAIN=yourdomain.com
APP_BASE_URL=https://yourdomain.com

# CORS / allowed origins
